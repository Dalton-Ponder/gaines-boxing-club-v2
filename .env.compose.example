#  Gaines Boxing Club V2 -- Docker Compose Env Template
#
#  This file is loaded by docker-compose.yml via env_file.
#  It contains environment variables needed by the website
#  service.
#
#  To use: copy this file to .env.compose
#    cp .env.compose.example .env.compose
# ─────────────────────────────────────────────────────────

# -- Shared (cross-project) --

# -- Gaines Boxing Club V2 --

# Payload CMS
# Generate a strong secret (min 32 bytes / 64 hex chars). Do NOT commit real values.
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your_payload_secret_here
DATABASE_URI=postgresql://user:password@pgbouncer:6432/database
