# ─────────────────────────────────────────────────────────
#  Gaines Boxing Club V2 -- Environment Template
#
#  Standalone environment template for production or local
#  testing outside Docker Compose. Uses the same keys as
#  .env.compose.example.
#
#  To use: copy this file to .env
#    cp .env.example .env
# ─────────────────────────────────────────────────────────

# -- Gaines Boxing Club V2 --

# Payload CMS
# Generate a strong secret (min 32 bytes / 64 hex chars). Do NOT commit real values.
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your_payload_secret_here

# Payload CMS database connection string (PostgreSQL).
# WARNING: Never commit real credentials. Store production secrets in a secure
# vault or environment manager and rotate them regularly. The value below is a
# safe placeholder for .env.example only.
DATABASE_URI=postgresql://user:password@localhost:5432/database
